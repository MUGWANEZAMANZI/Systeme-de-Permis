<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fitsSystemWindows="true"
    android:padding="8dp"
    android:background="#fff"
    android:layout_marginBottom="4dp">
    <TextView android:id="@+id/penalty_type" android:textStyle="bold" android:textColor="#d32f2f" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/penalty_amount" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/penalty_date" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/penalty_status" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
