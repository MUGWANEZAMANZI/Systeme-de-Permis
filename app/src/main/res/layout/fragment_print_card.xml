<?xml version="1.0" encoding="utf-8"?>


<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fitsSystemWindows="true"
    android:background="@color/police"
    android:layout_marginTop="?attr/actionBarSize"
    android:padding="16dp">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/search_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/input_license_number"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Enter license number"
                    android:inputType="textCapCharacters"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_search"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Search" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

            <TextView
                android:id="@+id/info_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="Enter a license number to search."
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cards_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <!-- FRONT CARD - Standard NFC card size: 85.6mm x 53.98mm -->
            <androidx.cardview.widget.CardView
                android:id="@+id/front_card"
                android:layout_width="320dp"
                android:layout_height="202dp"
                android:layout_margin="12dp"
                android:backgroundTint="#d6e7d3"
                android:clipToPadding="false"
                android:elevation="8dp"
                app:cardCornerRadius="8dp">

                <ImageView
                    android:id="@+id/background_watermark_afc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@mipmap/logo_afc_foreground"
                    android:scaleType="fitCenter"
                    android:alpha="0.1" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/card_emblem"
                        android:layout_width="40dp"
                        android:layout_height="26dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="2dp"
                        android:contentDescription="Provincial Emblem"
                        android:src="@mipmap/logo_afc_foreground" />

                    <ImageView
                        android:id="@+id/card_flag"
                        android:layout_width="40dp"
                        android:layout_height="26dp"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="National Flag"
                        android:scaleType="fitCenter"
                        android:src="@drawable/flag" />

                    <LinearLayout
                        android:id="@+id/card_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/card_emblem"
                        android:layout_marginStart="32dp"
                        android:layout_marginTop="1dp"
                        android:layout_marginEnd="32dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/main_info_block"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/card_header"
                        android:layout_marginTop="8dp"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <ImageView
                                android:id="@+id/card_profile"
                                android:layout_width="48dp"
                                android:layout_height="60dp"
                                android:layout_marginEnd="8dp"
                                android:background="#FFFFFF"
                                android:contentDescription="Profile image of the license holder"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_person" />

                            <TextView
                                android:id="@+id/card_number"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:gravity="center"
                                android:text="ABC-123456"
                                android:textSize="6sp"
                                android:textColor="@android:color/black" />

                        </LinearLayout>



                        <LinearLayout
                            android:id="@+id/card_info"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/card_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="1dp"
                                android:text="Nom: N/A"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/card_surname"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="1dp"
                                android:text="Prénom: N/A"
                                android:textSize="8sp" />

                            <TextView
                                android:id="@+id/card_dob"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="1dp"
                                android:text="Date &amp; Lieu de Naissance: N/A"
                                android:textSize="7sp" />

                            <TextView
                                android:id="@+id/card_nationality"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="1dp"
                                android:text="Nationalité: N/A"
                                android:textSize="7sp" />

                            <TextView
                                android:id="@+id/card_nationalId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="1dp"
                                android:text="N° National: N/A"
                                android:textSize="7sp" />

                            <TextView
                                android:id="@+id/card_address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="Adresse: N/A"
                                android:textSize="7sp" />

                            <LinearLayout
                                android:id="@+id/category_holders_row"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/border_for_categories"
                                android:orientation="horizontal"
                                android:padding="2dp">

                                <TextView
                                    style="@style/CategoryText"
                                    android:gravity="center"
                                    android:minWidth="16dp"
                                    android:text="A"
                                    android:textSize="7sp" />

                                <View style="@style/VerticalDivider" />

                                <TextView
                                    style="@style/CategoryText"
                                    android:gravity="center"
                                    android:minWidth="16dp"
                                    android:text="B"
                                    android:textSize="7sp" />

                                <View style="@style/VerticalDivider" />

                                <TextView
                                    style="@style/CategoryText"
                                    android:gravity="center"
                                    android:minWidth="16dp"
                                    android:text="C"
                                    android:textSize="7sp" />

                                <View style="@style/VerticalDivider" />

                                <TextView
                                    style="@style/CategoryText"
                                    android:gravity="center"
                                    android:minWidth="16dp"
                                    android:text="D"
                                    android:textSize="7sp" />

                                <View style="@style/VerticalDivider" />

                                <TextView
                                    style="@style/CategoryText"
                                    android:gravity="center"
                                    android:minWidth="16dp"
                                    android:text="E"
                                    android:textSize="7sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_dates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="4dp"
                        android:gravity="start"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/card_issue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Délivré le: N/A"
                            android:textSize="7sp" />

                        <TextView
                            android:id="@+id/card_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Expire le: N/A"
                            android:textSize="7sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/places"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="4dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/lieu_date_de_livraison"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lieu &amp; Daate de Livraison: N/A"
                            android:textSize="7sp" />


                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/anti_forgery_lines"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="183dp"
                        android:orientation="vertical">

                    </LinearLayout>




                    <TextView
                        android:id="@+id/card_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginStart="55dp"
                        android:layout_marginEnd="19dp"
                        android:layout_toStartOf="@+id/card_flag"
                        android:gravity="center"
                        android:text="REPUBLIQUE DEMOCRATIQUE DU CONGO"
                        android:textColor="#000000"
                        android:textSize="7sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/card_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/card_title"
                        android:layout_alignParentEnd="true"
                        android:layout_marginStart="22dp"
                        android:layout_marginTop="3dp"
                        android:layout_marginEnd="69dp"
                        android:layout_toEndOf="@+id/card_emblem"
                        android:gravity="center"
                        android:text="ATTESTATION TENANT LIEU DE PERMIS DE CONDUIRE"
                        android:textColor="#CC0000"
                        android:textSize="7sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="34dp"
                        android:alpha="0.3"
                        android:rotation="90"
                        android:text="ALLIANCE FLEUVE CONGO"
                        android:textSize="7sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="261dp"
                        android:layout_marginBottom="34dp"
                        android:alpha="0.3"
                        android:rotation="90"
                        android:text="xxxxxxxxxx"
                        android:textSize="7sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- BACK CARD - Standard NFC card size: 85.6mm x 53.98mm -->
            <androidx.cardview.widget.CardView
                android:id="@+id/back_card"
                android:layout_width="320dp"
                android:layout_height="202dp"
                android:layout_margin="12dp"
                android:backgroundTint="#d6e7d3"
                android:elevation="8dp"
                app:cardCornerRadius="8dp">

                <ImageView
                    android:id="@+id/background_watermark"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@mipmap/flag_north"
                    android:scaleType="fitCenter"
                    android:alpha="0.1" />


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/qr_code"
                        android:layout_width="73dp"
                        android:layout_height="48dp"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="QR Code for verification"
                        android:src="@drawable/ic_qr_placeholder" />

                    <ImageView
                        android:id="@+id/anti_forgery_circle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="15dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/anti_forgery_circle_gradient"
                        android:contentDescription="Anti-forgery holographic element" />

                    <TextView
                        android:id="@+id/license_number_back"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/anti_forgery_circle"
                        android:layout_alignParentStart="true"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="6dp"
                        android:text="Permis No: N/A"
                        android:textColor="@android:color/black"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/vehicle_categories_table"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/license_number_back"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/table_border"
                        android:orientation="vertical"
                        android:padding="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="18dp"

                            android:background="#E0E0E0"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/CategoryTableHeaderText"
                                android:layout_width="32dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="Cat."

                                android:textSize="4sp" />

                            <View style="@style/VerticalDividerThin" />

                            <TextView
                                style="@style/CategoryTableHeaderText"
                                android:layout_width="0dp"
                                android:layout_margin="0dp"
                                android:layout_weight="2"
                                android:gravity="center"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="0dp"
                                android:text="Type de Vehicule"
                                android:textSize="6sp" />

                            <View style="@style/VerticalDividerThin" />

                            <TextView
                                style="@style/CategoryTableHeaderText"
                                android:layout_width="48dp"
                                android:layout_margin="0dp"
                                android:gravity="center"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="0dp"
                                android:text="Authorise"
                                android:textSize="8sp" />
                        </LinearLayout>

                        <View style="@style/HorizontalDividerThin" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="18dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="32dp"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:gravity="center"
                                android:text="A"
                                android:textSize="6sp" />

                            <View style="@style/VerticalDividerThin" />

                            <ImageView
                                android:layout_width="0dp"
                                android:layout_height="14dp"
                                android:layout_weight="2"
                                android:contentDescription="Motorcycle"
                                android:padding="1dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_motorcycle" />

                            <View style="@style/VerticalDividerThin" />

                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="48dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="No"
                                android:textSize="5sp" />
                        </LinearLayout>

                        <View style="@style/HorizontalDividerThin" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="32dp"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:gravity="center"
                                android:text="B"
                                android:textSize="5sp" />
                            <View style="@style/VerticalDividerThin" />
                            <ImageView
                                android:layout_width="0dp"
                                android:layout_height="14dp"
                                android:layout_weight="2"
                                android:contentDescription="Car"
                                android:padding="1dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_car" />
                            <View style="@style/VerticalDividerThin" />
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="48dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="No"
                                android:textSize="5sp" />
                        </LinearLayout>

                        <View style="@style/HorizontalDividerThin" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="32dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="C"
                                android:textSize="5sp" />
                            <View style="@style/VerticalDividerThin" />
                            <ImageView
                                android:layout_width="0dp"
                                android:layout_height="14dp"
                                android:layout_weight="2"
                                android:contentDescription="Truck"
                                android:padding="1dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_truck" />
                            <View style="@style/VerticalDividerThin" />
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="48dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="No"
                                android:textSize="5sp" />
                        </LinearLayout>

                        <View style="@style/HorizontalDividerThin" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="32dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="D"
                                android:textSize="5sp" />
                            <View style="@style/VerticalDividerThin" />
                            <ImageView
                                android:layout_width="0dp"
                                android:layout_height="14dp"
                                android:layout_weight="2"
                                android:contentDescription="Bus"
                                android:padding="1dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_bus" />
                            <View style="@style/VerticalDividerThin" />
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="48dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="No"
                                android:textSize="5sp" />
                        </LinearLayout>

                        <View style="@style/HorizontalDividerThin" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="32dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="E"
                                android:textSize="5sp" />
                            <View style="@style/VerticalDividerThin" />
                            <ImageView
                                android:layout_width="0dp"
                                android:layout_height="14dp"
                                android:layout_weight="2"
                                android:contentDescription="Trailer"
                                android:padding="1dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_trailer" />
                            <View style="@style/VerticalDividerThin" />
                            <TextView
                                style="@style/CategoryTableItemText"
                                android:layout_width="48dp"
                                android:gravity="center"
                                android:padding="0dp"
                                android:layout_margin="0dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="No"
                                android:textSize="5sp" />
                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/micro_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_above="@id/license_disclaimer"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="2dp"
                        android:ellipsize="none"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="RDC-Nord-Kivu-Gouvernement-RDC-Nord-Kivu-Gouvernement"
                        android:textColor="#000000"
                        android:textSize="2sp" />

                    <TextView
                        android:id="@+id/license_disclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="4dp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="0.9"
                        android:text="Ce permis de conduire est la propriété de la République Démocratique du Congo.\nSi trouvé, prière de le remettre au poste de police le plus proche."
                        android:textColor="@android:color/black"
                        android:textSize="6sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/save_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:backgroundTint="@android:color/holo_blue_dark"
                android:paddingHorizontal="24dp"
                android:text="Sauvegarder sur le téléphone"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
